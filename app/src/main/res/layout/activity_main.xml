<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rumda_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/statusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_rumda_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/statusTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/rumda_text_dark"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusBodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/rumda_text_muted"
                android:textSize="16sp" />

            <Button
                android:id="@+id/primaryActionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/checklistCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_rumda_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/checklistTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_checklist_title"
                android:textColor="@color/rumda_text_dark"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/checklistBodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/main_checklist_body"
                android:textColor="@color/rumda_text_muted"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/apkCheckBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/main_collection_apk"
                android:textColor="@color/rumda_text_dark"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/ipsCheckBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/main_collection_ips"
                android:textColor="@color/rumda_text_dark"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/servicesCheckBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/main_collection_services"
                android:textColor="@color/rumda_text_dark"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
